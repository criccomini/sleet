{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "sleet verify record",
  "description": "One periodic verification outcome: `verify/<db>.<target>.json` at\nthe fleet root, written by the owning daemon task on the target's\n`verify_interval` and read by `sleet status --mirrors`. The record\nis observability-only, like a heartbeat body: readers ignore\nunknown fields, `version` bumps only on incompatible change, and a\nrecord for a retired target is inert.",
  "type": "object",
  "properties": {
    "database": {
      "description": "The source database's canonical URL.",
      "type": "string"
    },
    "destination": {
      "description": "The destination root verified.",
      "type": "string"
    },
    "node_id": {
      "description": "The node that ran the verification.",
      "type": "string"
    },
    "objects": {
      "description": "Objects checked across every restore point's closure.",
      "type": "integer",
      "format": "uint64",
      "minimum": 0
    },
    "ok": {
      "description": "Whether every restore point verified.",
      "type": "boolean"
    },
    "points": {
      "description": "Restore points checked.",
      "type": "integer",
      "format": "uint64",
      "minimum": 0
    },
    "problems": {
      "description": "Total problems found.",
      "type": "integer",
      "format": "uint64",
      "minimum": 0
    },
    "sample": {
      "description": "The first few problems.",
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "target": {
      "description": "The target's name.",
      "type": "string"
    },
    "verified_at": {
      "description": "When the verification finished.",
      "type": "string",
      "format": "date-time"
    },
    "version": {
      "description": "Record format version; bumped only on incompatible change.",
      "type": "integer",
      "format": "uint32",
      "minimum": 0
    }
  },
  "required": [
    "version",
    "node_id",
    "database",
    "target",
    "destination",
    "verified_at",
    "ok",
    "points",
    "objects",
    "problems"
  ]
}
