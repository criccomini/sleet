{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "sleet validate response",
  "description": "The `sleet validate` response.",
  "type": "object",
  "properties": {
    "errors": {
      "description": "Problems found; empty when valid.",
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "spec": {
      "description": "Path of the spec that was checked.",
      "type": "string"
    },
    "valid": {
      "description": "Whether the spec parsed and validated.",
      "type": "boolean"
    }
  },
  "required": [
    "spec",
    "valid",
    "errors"
  ]
}
