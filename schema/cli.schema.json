{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "sleet response",
  "description": "A response from any subcommand run with `--format json`, one variant\nper command. Exists to generate the single response schema: each\ncommand's response is a named definition under `$defs`, so consumers\nvalidate against e.g. `#/$defs/StatusResponse`.",
  "anyOf": [
    {
      "$ref": "#/$defs/StatusResponse"
    }
  ],
  "$defs": {
    "DatabaseStatus": {
      "description": "One managed database and its service assignments.",
      "type": "object",
      "properties": {
        "services": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ServiceStatus"
          }
        },
        "url": {
          "type": "string"
        }
      },
      "required": [
        "url",
        "services"
      ]
    },
    "HumanDuration": {
      "description": "A duration in humantime form, e.g. \"10s\", \"5m\", \"1h 30m\".",
      "type": "string",
      "pattern": "^([0-9]+ *[a-zµ]+ *)+$"
    },
    "NodeStatus": {
      "description": "One fleet member.",
      "type": "object",
      "properties": {
        "heartbeat_age": {
          "description": "Age of the heartbeat object.",
          "$ref": "#/$defs/HumanDuration"
        },
        "live": {
          "description": "Whether the heartbeat is younger than `node_timeout`.",
          "type": "boolean"
        },
        "node_id": {
          "type": "string"
        }
      },
      "required": [
        "node_id",
        "live",
        "heartbeat_age"
      ]
    },
    "Service": {
      "description": "A per-database service.",
      "oneOf": [
        {
          "description": "Garbage collection.",
          "type": "string",
          "const": "gc"
        },
        {
          "description": "Standalone compaction coordinator (RFC-0025).",
          "type": "string",
          "const": "compactor"
        },
        {
          "description": "Compaction worker pool (RFC-0025).",
          "type": "string",
          "const": "workers"
        }
      ]
    },
    "ServiceState": {
      "description": "Supervised task state for one service.",
      "oneOf": [
        {
          "description": "The task is running.",
          "type": "string",
          "const": "running"
        },
        {
          "description": "The task crashed and is waiting out its restart delay.",
          "type": "string",
          "const": "backoff"
        },
        {
          "description": "The task was shut down (unassigned or removed from the spec).",
          "type": "string",
          "const": "stopped"
        }
      ]
    },
    "ServiceStatus": {
      "description": "One `(database, service)` assignment.",
      "type": "object",
      "properties": {
        "node_id": {
          "description": "Node the service is rendezvous-hashed to.",
          "type": "string"
        },
        "service": {
          "$ref": "#/$defs/Service"
        },
        "state": {
          "$ref": "#/$defs/ServiceState"
        }
      },
      "required": [
        "service",
        "node_id",
        "state"
      ]
    },
    "StatusResponse": {
      "title": "sleet status response",
      "description": "The `sleet status` response, derived from object storage: node\nliveness from heartbeat ages, assignments and service states from\nheartbeat contents.",
      "type": "object",
      "properties": {
        "databases": {
          "description": "Managed databases and their service assignments.",
          "type": "array",
          "items": {
            "$ref": "#/$defs/DatabaseStatus"
          }
        },
        "nodes": {
          "description": "Every fleet member with a heartbeat object.",
          "type": "array",
          "items": {
            "$ref": "#/$defs/NodeStatus"
          }
        }
      },
      "required": [
        "nodes",
        "databases"
      ]
    }
  }
}
